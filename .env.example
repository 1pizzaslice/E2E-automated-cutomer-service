NODE_ENV=development
LOG_LEVEL=info

API_HOST=0.0.0.0
API_PORT=3000

DATABASE_URL=postgres://support:support@localhost:5432/support
REDIS_URL=redis://localhost:6380
NATS_URL=nats://localhost:4222
TEMPORAL_ADDRESS=localhost:7233
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=support-artifacts
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# AI runtime sidecar bridge (Milestone 14). When AI_RUNTIME_SERVICE_URL is set
# the worker's runAiGraph activity calls the Python sidecar; unset keeps the
# in-process deterministic stand-in. Token variables hold local development
# values; the *_REF conventions (AI_RUNTIME_SERVICE_TOKEN_REF,
# SUPPORT_AI_SERVICE_TOKEN_REF, SUPPORT_API_TOKEN_REF,
# SUPPORT_INTERNAL_API_TOKEN_REF) let deployments point at differently named
# secrets.
AI_RUNTIME_SERVICE_URL=http://localhost:8090
SUPPORT_AI_SERVICE_TOKEN=local-ai-service-token
SUPPORT_INTERNAL_API_TOKEN=local-internal-api-token
