# This file configures LOCAL development (pnpm dev / pnpm infra:up). For the
# staging/production single-VM deployment, secrets live in
# infra/production/.env + infra/production/env/*.env (see
# infra/production/README.md); do not reuse these dev values there.
NODE_ENV=development
LOG_LEVEL=info

API_HOST=0.0.0.0
API_PORT=3000

DATABASE_URL=postgres://support:support@localhost:5432/support
REDIS_URL=redis://localhost:6380
NATS_URL=nats://localhost:4222

# ---- console enablement (Milestone 20, ADR-0026) --------------------------
# CORS is OFF unless origins are listed here (comma-separated, exact match; the
# "*" wildcard is rejected). The reviewer console runs on its own origin.
#SUPPORT_CORS_ALLOWED_ORIGINS=http://localhost:5173
#SUPPORT_CORS_ALLOW_CREDENTIALS=false
# Rate limiting is OFF unless enabled; when on it uses REDIS_URL for shared
# counters (the platform's first production use of Redis) and falls back to an
# in-process store only if REDIS_URL is unset. Limit is per authenticated
# principal; health probes and provider webhooks are exempt.
#SUPPORT_RATE_LIMIT_ENABLED=true
#SUPPORT_RATE_LIMIT_MAX=300
#SUPPORT_RATE_LIMIT_WINDOW_MS=60000

TEMPORAL_ADDRESS=localhost:7233
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=support-artifacts
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# AI runtime sidecar bridge (Milestone 14). When AI_RUNTIME_SERVICE_URL is set
# the worker's runAiGraph activity calls the Python sidecar; unset keeps the
# in-process deterministic stand-in. Token variables hold local development
# values; the *_REF conventions (AI_RUNTIME_SERVICE_TOKEN_REF,
# SUPPORT_AI_SERVICE_TOKEN_REF, SUPPORT_API_TOKEN_REF,
# SUPPORT_INTERNAL_API_TOKEN_REF) let deployments point at differently named
# secrets.
AI_RUNTIME_SERVICE_URL=http://localhost:8090
SUPPORT_AI_SERVICE_TOKEN=local-ai-service-token
SUPPORT_INTERNAL_API_TOKEN=local-internal-api-token

# User authentication (Milestone 16, ADR-0024). The API default is JWT mode:
# IdP-issued tokens verified against the issuer's JWKS (issuer + audience are
# REQUIRED; a JWT-mode boot missing either fails fast). The pilot IdP is
# Clerk; the dashboard session-token customization must add
# {"aud": "<audience>", "email": "{{user.primary_email_address}}"} because
# default Clerk v2 session tokens carry neither claim. Verified subjects map
# to users.idp_subject; roles stay DB-sourced (user_roles). The trusted
# x-user-* header mode survives ONLY behind the explicit opt-in below —
# never set it in production.
SUPPORT_AUTH_ISSUER=https://your-instance.clerk.accounts.dev
SUPPORT_AUTH_AUDIENCE=support-platform-api
#SUPPORT_AUTH_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
#SUPPORT_AUTH_CLOCK_TOLERANCE_S=60
# Local/test escape hatch (explicit, default off):
#SUPPORT_AUTH_MODE=insecure-headers
# Clerk backend key for ops tooling and the opt-in live auth smoke
# (RUN_CLERK_LIVE_TESTS=true); never used by the API itself.
#CLERK_SECRET_KEY=sk_test_...
# Optional pilot-seed links from seeded users to real IdP identities
# (pnpm db:seed:pilot); unlinked users cannot sign in under JWT auth.
#PILOT_SEED_OPS_IDP_SUBJECT=user_...
#PILOT_SEED_AGENT_IDP_SUBJECT=user_...
#PILOT_SEED_QA_IDP_SUBJECT=user_...

# Real model provider for the AI sidecar (Milestone 15, ADR-0020). Unset keeps
# the deterministic offline model; real providers activate only by explicit
# config and require the provider key (SUPPORT_LLM_API_KEY_REF names the key
# variable; defaults: anthropic->ANTHROPIC_API_KEY, openai->OPENAI_API_KEY).
# Pilot default: Anthropic Claude claude-sonnet-5 (2026-07-07 live gates:
# golden 25 PASS topic 0.960/routing 1.0, injection 18 PASS rate 1.0;
# claude-opus-4-8 also PASSed both suites and is a config-only upgrade).
# SUPPORT_LLM_PROVIDER=scripted runs the offline provider-agnosticism
# stand-in (no key needed). A provider or model swap must re-run the eval
# gates (SOPS §11.1): `python -m evals.live_runner`.
#SUPPORT_LLM_PROVIDER=anthropic
#SUPPORT_LLM_MODEL=claude-sonnet-5
#ANTHROPIC_API_KEY=sk-ant-...
#SUPPORT_LLM_TIMEOUT_MS=30000
#SUPPORT_LLM_MAX_RETRIES=2

# Embedding provider shared by KB ingestion and retrieval (Milestone 15).
# Unset keeps the deterministic embedder; the pilot default is OpenAI
# text-embedding-3-small (1536-dim, matching the vector(1536) column).
# Switching embedding providers changes the embedding space: re-ingest every
# KB document afterwards — retrieval fails closed (409) on a model mismatch.
#SUPPORT_EMBEDDING_PROVIDER=openai
#SUPPORT_EMBEDDING_MODEL=text-embedding-3-small
#OPENAI_API_KEY=sk-...

# Retrieval bounds applied before results reach the AI runtime (Milestone 15).
# Defaults: floor 0 (keep everything; right for the deterministic embedder),
# cap 24000 chars. With real embeddings, raise the floor per environment —
# suggested pilot value for text-embedding-3-small: 0.25.
#SUPPORT_KB_MIN_SIMILARITY=0.25
#SUPPORT_KB_MAX_CONTEXT_CHARS=24000

# Scheduled jobs (Milestone 17, ADR-0025). On every start the worker
# entrypoint ensures one daily QA sampling and one daily retention Temporal
# Schedule per active tenant (create-if-missing; existing schedules and
# operator edits are left untouched). Times are UTC HH:MM; fire times get up
# to 5 minutes of jitter. Set SUPPORT_JOB_SCHEDULES=disabled to skip the
# bootstrap (local debugging only — without schedules the jobs never run).
#SUPPORT_JOB_SCHEDULES=enabled
#SUPPORT_QA_SAMPLING_SCHEDULE_UTC=02:00
#SUPPORT_RETENTION_SCHEDULE_UTC=02:30
# Base directory the retention blob sweeper may delete file:// refs from
# (must match the API's raw payload store location).
#RAW_PAYLOAD_STORE_DIR=.data/raw-payloads
