NODE_ENV=development
LOG_LEVEL=info

API_HOST=0.0.0.0
API_PORT=3000

DATABASE_URL=postgres://support:support@localhost:5432/support
REDIS_URL=redis://localhost:6380
NATS_URL=nats://localhost:4222
TEMPORAL_ADDRESS=localhost:7233
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=support-artifacts
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# AI runtime sidecar bridge (Milestone 14). When AI_RUNTIME_SERVICE_URL is set
# the worker's runAiGraph activity calls the Python sidecar; unset keeps the
# in-process deterministic stand-in. Token variables hold local development
# values; the *_REF conventions (AI_RUNTIME_SERVICE_TOKEN_REF,
# SUPPORT_AI_SERVICE_TOKEN_REF, SUPPORT_API_TOKEN_REF,
# SUPPORT_INTERNAL_API_TOKEN_REF) let deployments point at differently named
# secrets.
AI_RUNTIME_SERVICE_URL=http://localhost:8090
SUPPORT_AI_SERVICE_TOKEN=local-ai-service-token
SUPPORT_INTERNAL_API_TOKEN=local-internal-api-token

# Real model provider for the AI sidecar (Milestone 15, ADR-0020). Unset keeps
# the deterministic offline model; real providers activate only by explicit
# config and require the provider key (SUPPORT_LLM_API_KEY_REF names the key
# variable; defaults: anthropic->ANTHROPIC_API_KEY, openai->OPENAI_API_KEY).
# Pilot default: Anthropic Claude. SUPPORT_LLM_PROVIDER=scripted runs the
# offline provider-agnosticism stand-in (no key needed). A provider or model
# swap must re-run the eval gates (SOPS §11): `python -m evals.live_runner`.
#SUPPORT_LLM_PROVIDER=anthropic
#SUPPORT_LLM_MODEL=claude-opus-4-8
#ANTHROPIC_API_KEY=sk-ant-...
#SUPPORT_LLM_TIMEOUT_MS=30000
#SUPPORT_LLM_MAX_RETRIES=2

# Embedding provider shared by KB ingestion and retrieval (Milestone 15).
# Unset keeps the deterministic embedder; the pilot default is OpenAI
# text-embedding-3-small (1536-dim, matching the vector(1536) column).
# Switching embedding providers changes the embedding space: re-ingest every
# KB document afterwards — retrieval fails closed (409) on a model mismatch.
#SUPPORT_EMBEDDING_PROVIDER=openai
#SUPPORT_EMBEDDING_MODEL=text-embedding-3-small
#OPENAI_API_KEY=sk-...

# Retrieval bounds applied before results reach the AI runtime (Milestone 15).
# Defaults: floor 0 (keep everything; right for the deterministic embedder),
# cap 24000 chars. With real embeddings, raise the floor per environment —
# suggested pilot value for text-embedding-3-small: 0.25.
#SUPPORT_KB_MIN_SIMILARITY=0.25
#SUPPORT_KB_MAX_CONTEXT_CHARS=24000
