{
  "uid": "support-overview",
  "title": "Support Platform Overview",
  "description": "API traffic, workflow activity health, AI runs, tool calls, approvals, and critical failures for the automated customer service platform (Milestone 11). Datasource: any Prometheus-compatible store scraping the otel-collector prometheus exporter (:8889).",
  "tags": ["support", "observability"],
  "schemaVersion": 39,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "API request rate by route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(support_api_requests[5m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API p95 latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(support_api_request_duration_ms_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(support_api_request_duration_ms_bucket[5m])))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "API 5xx error rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(support_api_requests{http_response_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(support_api_requests[5m])), 1e-9)",
          "legendFormat": "5xx ratio"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Workflow activity executions by outcome",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (activity, outcome) (rate(support_workflow_activity_executions[5m]))",
          "legendFormat": "{{activity}} {{outcome}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "AI runs by status and automation mode",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (status, automation_mode) (rate(support_ai_run_completions[15m]))",
          "legendFormat": "{{status}} / {{automation_mode}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "AI run p95 duration (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(support_ai_run_duration_ms_bucket[15m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Tool calls by tool and status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (tool, status) (rate(support_tool_call_executions[15m]))",
          "legendFormat": "{{tool}} {{status}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Approvals: requested vs decided",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(support_approval_requests[15m]))",
          "legendFormat": "requested"
        },
        {
          "expr": "sum by (decision) (rate(support_approval_decisions[15m]))",
          "legendFormat": "decided: {{decision}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Approval decision latency p95 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(support_approval_latency_ms_bucket[30m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Critical failures by mode",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "sum by (failure_mode) (increase(support_critical_failures[15m]))",
          "legendFormat": "{{failure_mode}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Scheduled job runs by job and outcome",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "sum by (job, outcome) (increase(support_job_executions[24h]))",
          "legendFormat": "{{job}} {{outcome}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Retention items purged by class",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [
        {
          "expr": "sum by (retention_class) (increase(support_retention_purged_items[24h]))",
          "legendFormat": "{{retention_class}}"
        }
      ]
    }
  ]
}
