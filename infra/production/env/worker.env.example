# infra/production/env/worker.env — worker app config (Milestone 18).
# Copy to `worker.env`, fill in, keep out of git. Datastore URLs, the AI
# sidecar URL, and the AI service token are injected by the Compose profile
# from ../.env — do not duplicate them here.

# ---- approval expiry (BACKEND_SPEC §12, ADR-0021) -------------------------
# Absolute wait recorded in workflow history; 24h default, 0 disables.
# APPROVAL_EXPIRY_MS=86400000

# ---- scheduled jobs (Milestone 17, ADR-0025) ------------------------------
# Per-tenant daily QA-sampling + retention Temporal Schedules are bootstrapped
# on start (create-if-missing; operator edits survive restarts). Times are UTC
# HH:MM and get up to 5 minutes of jitter. Set SUPPORT_JOB_SCHEDULES=disabled
# only for local debugging — without schedules the jobs never fire.
# SUPPORT_JOB_SCHEDULES=enabled
# SUPPORT_QA_SAMPLING_SCHEDULE_UTC=02:00
# SUPPORT_RETENTION_SCHEDULE_UTC=02:30
