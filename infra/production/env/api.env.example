# infra/production/env/api.env — API external secrets (Milestone 18).
# Copy to `api.env`, fill in, keep out of git. Internal endpoints, the internal
# machine token, and datastore URLs are injected by the Compose profile from
# ../.env — do not duplicate them here.

# ---- user authentication (Milestone 16, ADR-0024) -------------------------
# JWT mode is the API default and REQUIRES both issuer and audience (a boot
# missing either fails fast). Pilot IdP = Clerk PRODUCTION instance (not the
# dev instance). The Clerk session-token template must add the aud + email
# claims (see .env.example in the repo root for the exact JSON).
SUPPORT_AUTH_ISSUER=https://your-prod-instance.clerk.accounts.dev
SUPPORT_AUTH_AUDIENCE=support-platform-api
# SUPPORT_AUTH_JWKS_URL=            # defaults to <issuer>/.well-known/jwks.json
# SUPPORT_AUTH_CLOCK_TOLERANCE_S=60
# NEVER set SUPPORT_AUTH_MODE=insecure-headers in staging/production.

# ---- embeddings (KB ingestion + retrieval run in the API) -----------------
# Pilot default OpenAI text-embedding-3-small (1536-dim). Unset keeps the
# deterministic embedder. Switching providers requires a full KB re-embed
# (retrieval fails closed 409 on a model mismatch — SOPS §11.2).
# SUPPORT_EMBEDDING_PROVIDER=openai
# SUPPORT_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...
# SUPPORT_KB_MIN_SIMILARITY=0.25
# SUPPORT_KB_MAX_CONTEXT_CHARS=24000

# ---- pilot seed identity links (used by the `seed` one-shot) --------------
# Unlinked seeded users cannot sign in under JWT auth.
# PILOT_SEED_OPS_IDP_SUBJECT=user_...
# PILOT_SEED_AGENT_IDP_SUBJECT=user_...
# PILOT_SEED_QA_IDP_SUBJECT=user_...

# ---- channel secrets, INBOUND side (Milestone 19) -------------------------
# Channel config rows store a REFERENCE (the env var name), never the value
# (BACKEND_SPEC §4.1) — these are the values the pilot seed's refs point at.
# The API verifies inbound signatures and answers Meta's subscription
# handshake, so the INBOUND secrets live here; the worker sends, so its
# credentials live in worker.env. A missing value fails closed: signature
# verification returns 403 rather than trusting an unsigned webhook.
#
# Mailgun HTTP webhook signing key (Sending -> Webhooks; NOT the send API key).
# PILOT_MAILGUN_SIGNING_KEY=
# WhatsApp Cloud app secret; Meta signs the raw body with it (X-Hub-Signature-256).
# PILOT_WHATSAPP_APP_SECRET=
# A string YOU choose, entered in the Meta dashboard when subscribing the
# callback URL. Meta echoes it back on the GET handshake and the API compares it.
# PILOT_WHATSAPP_VERIFY_TOKEN=

# ---- console enablement (Milestone 20, ADR-0026) --------------------------
# The reviewer console runs on its own origin, so list it here (comma-separated,
# exact match; "*" is rejected). Unset keeps CORS off (same-origin only).
# SUPPORT_CORS_ALLOWED_ORIGINS=https://console.your-domain.example
# SUPPORT_CORS_ALLOW_CREDENTIALS=false
# Per-principal rate limiting on authenticated endpoints, counters in Redis
# (REDIS_URL is injected by the Compose profile from ../.env). Unset keeps it
# off. Health probes and provider webhooks are always exempt.
# SUPPORT_RATE_LIMIT_ENABLED=true
# SUPPORT_RATE_LIMIT_MAX=300
# SUPPORT_RATE_LIMIT_WINDOW_MS=60000
