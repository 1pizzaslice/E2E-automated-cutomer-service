# infra/production/.env — Compose interpolation + shared secrets (Milestone 18).
#
# Copy to `.env`, fill in real values, and keep it OUT of git
# (infra/production/.gitignore already ignores it). Values here are the single
# source of truth for things used by more than one service (datastore
# passwords, the internal machine tokens that MUST match across api/worker/ai,
# image coordinates). Per-service external provider/IdP keys live in
# ./env/<service>.env instead.

# ---- container images (CI pushes to GHCR; the VM pulls) --------------------
REGISTRY=ghcr.io/1pizzaslice
IMAGE_TAG=latest

# ---- edge / TLS ------------------------------------------------------------
# Public hostname Caddy terminates TLS for. Use `localhost` for a local drill
# (Caddy serves a locally-trusted internal cert; curl -k).
STAGING_DOMAIN=staging.example.com
ACME_EMAIL=ops@example.com

# ---- datastore credentials (use strong, unique values) ---------------------
POSTGRES_PASSWORD=change-me-postgres
REDIS_PASSWORD=change-me-redis
MINIO_ROOT_USER=support
MINIO_ROOT_PASSWORD=change-me-minio

# ---- internal machine tokens (ADR-0022) ------------------------------------
# Single-sourced BECAUSE they must match across api/worker/ai. Rotation is a
# value change here + `docker compose up -d` to restart the three services.
SUPPORT_INTERNAL_API_TOKEN=change-me-internal-token
SUPPORT_AI_SERVICE_TOKEN=change-me-ai-service-token

# ---- monitoring ------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana
# Alertmanager Slack webhook. Leave blank to provision Alertmanager WITHOUT
# delivery (alerts still fire + show in the UI at 127.0.0.1:9093); paste the
# incoming-webhook URL to turn delivery on.
SLACK_WEBHOOK_URL=

# ---- AI sidecar ------------------------------------------------------------
SUPPORT_UVICORN_WORKERS=2

# ---- backups ---------------------------------------------------------------
BACKUP_RETENTION_DAYS=14
BACKUP_SCHEDULE_UTC=01:30
# Optional offsite shipping hook. Invoked as: bash -c "$BACKUP_UPLOAD_CMD" _ <dumpfile>
# so the dump path is $1. The tool must exist in the pg-backup image or a
# sidecar. Example: BACKUP_UPLOAD_CMD=rclone copy "$1" offsite:support-pg-backups/
BACKUP_UPLOAD_CMD=

# ---- misc ------------------------------------------------------------------
LOG_LEVEL=info
SUPPORT_ENVIRONMENT=staging
